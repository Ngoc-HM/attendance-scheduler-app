# Copy to .env and adjust. Never commit the real .env (it holds secrets).
ENVIRONMENT=dev
PROJECT_NAME=Attendance & Auto-Scheduler API
API_V1_STR=/api/v1

# Security
SECRET_KEY=please-generate-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# First admin (F-01) — seeded/reset to these values on every backend startup
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=admin123
FIRST_ADMIN_FULL_NAME=System Administrator
# Auto-create DB tables on startup (dev convenience). Use Alembic in prod.
AUTO_CREATE_TABLES=true

# Database (use an EU/Frankfurt-region PostgreSQL in production — spec §9.4)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/attendance

# CORS (comma-separated, or * for dev)
BACKEND_CORS_ORIGINS=*

# i18n + locale
DEFAULT_LANGUAGE=en
TIMEZONE=Europe/Berlin

# Scheduler
SOLVER_MAX_TIME_SECONDS=30
